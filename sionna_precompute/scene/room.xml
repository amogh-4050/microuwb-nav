<scene version="2.1.0">

<!-- ITU concrete for room envelope (walls, floor, ceiling). -->
<!-- Thickness matches the Gazebo world wall thickness (0.1 m).  -->

    <bsdf type="itu-radio-material" id="concrete">
        <string name="type" value="concrete"/>
        <float name="thickness" value="0.1"/>
    </bsdf>

<!-- ITU wood for furniture bounding boxes. -->
<!-- Thickness 0.02 m (nominal panel thickness). -->

    <bsdf type="itu-radio-material" id="wood">
        <string name="type" value="wood"/>
        <float name="thickness" value="0.02"/>
    </bsdf>

<!-- Room: 5 m × 4 m × 3 m, origin at SW floor corner.         -->
<!-- Interior spans (0,0,0) → (5,4,3) — identical to Gazebo.   -->
<!-- Surface normals point INTO the room (inward-facing).        -->

    <shape type="ply" id="mesh-floor">
        <string name="filename" value="meshes/floor.ply"/>
        <boolean name="face_normals" value="true"/>
        <ref id="concrete" name="bsdf"/>
    </shape>

    <shape type="ply" id="mesh-ceiling">
        <string name="filename" value="meshes/ceiling.ply"/>
        <boolean name="face_normals" value="true"/>
        <ref id="concrete" name="bsdf"/>
    </shape>

    <shape type="ply" id="mesh-wall-south">
        <string name="filename" value="meshes/wall_south.ply"/>
        <boolean name="face_normals" value="true"/>
        <ref id="concrete" name="bsdf"/>
    </shape>

    <shape type="ply" id="mesh-wall-north">
        <string name="filename" value="meshes/wall_north.ply"/>
        <boolean name="face_normals" value="true"/>
        <ref id="concrete" name="bsdf"/>
    </shape>

    <shape type="ply" id="mesh-wall-west">
        <string name="filename" value="meshes/wall_west.ply"/>
        <boolean name="face_normals" value="true"/>
        <ref id="concrete" name="bsdf"/>
    </shape>

    <shape type="ply" id="mesh-wall-east">
        <string name="filename" value="meshes/wall_east.ply"/>
        <boolean name="face_normals" value="true"/>
        <ref id="concrete" name="bsdf"/>
    </shape>

<!-- Furniture bounding boxes. Positions match room.world.xacro models.  -->
<!-- Each box is an AABB of the Gazebo model's collision geometry.        -->

    <shape type="ply" id="mesh-furniture-bookshelf">
        <string name="filename" value="meshes/furniture_bookshelf.ply"/>
        <boolean name="face_normals" value="true"/>
        <ref id="wood" name="bsdf"/>
    </shape>

    <shape type="ply" id="mesh-furniture-cafe-table">
        <string name="filename" value="meshes/furniture_cafe_table.ply"/>
        <boolean name="face_normals" value="true"/>
        <ref id="wood" name="bsdf"/>
    </shape>

    <shape type="ply" id="mesh-furniture-cabinet">
        <string name="filename" value="meshes/furniture_cabinet.ply"/>
        <boolean name="face_normals" value="true"/>
        <ref id="wood" name="bsdf"/>
    </shape>

</scene>
